# ─────────────────────────────────────────────
#  HireFlow – Environment Variables
# ─────────────────────────────────────────────
#  Copy this file to .env and fill in your values.
#  Never commit .env to version control.

# ──────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────
NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:5173

# ──────────────────────────────────────────────
# Database (PostgreSQL)
# ──────────────────────────────────────────────
POSTGRES_USER=hireflow
POSTGRES_PASSWORD=hireflow_secret
POSTGRES_DB=hireflow_db
DATABASE_URL=postgresql://hireflow:hireflow_secret@localhost:5432/hireflow_db

# ──────────────────────────────────────────────
# Cache (Redis)
# ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ──────────────────────────────────────────────
# Authentication
# ──────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ──────────────────────────────────────────────
# Email (SMTP) – Optional. Leave empty to log instead of send.
# ──────────────────────────────────────────────
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@hireflow.io

# ──────────────────────────────────────────────
# Cloud Storage – Optional. For video recording uploads.
# ──────────────────────────────────────────────
STORAGE_BUCKET=hireflow-recordings
STORAGE_REGION=ap-south-1

# ──────────────────────────────────────────────
# Frontend (Vite)
# ──────────────────────────────────────────────
VITE_API_URL=http://localhost:4000/api

# ──────────────────────────────────────────────
# Payments (Razorpay)
# ──────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# ──────────────────────────────────────────────
# OAuth (GitHub)
# ──────────────────────────────────────────────
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:4000/api/auth/github/callback

# ──────────────────────────────────────────────
# OAuth (LinkedIn)
# ──────────────────────────────────────────────
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_CALLBACK_URL=http://localhost:4000/api/auth/linkedin/callback
